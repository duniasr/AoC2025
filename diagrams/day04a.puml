@startumlclassDiagram

             class Coordinate {
                 <<record / Value Object>>
                 +row : int
                 +col : int
                 +streamAdjacent() Stream~Coordinate~
             }

             class PaperRollDiagram_PartA {
                 <<Immutable Domain>>
                 -grid : String[]
                 -PaperRollDiagram_PartA(grid: String[])
                 +from(rawDiagram: String)$ PaperRollDiagram_PartA
                 +countAccessibleRolls() long
                 -streamAllCoordinates() Stream~Coordinate~
                 -isAccessibleByForklift(target: Coordinate) boolean
                 -isRoll(target: Coordinate) boolean
                 -isWithinBounds(target: Coordinate) boolean
             }

             PaperRollDiagram_PartA ..> Coordinate : crea y evalúa
@enduml